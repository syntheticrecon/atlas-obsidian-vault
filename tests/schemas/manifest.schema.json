{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Raw Source Manifest",
  "description": "Schema for raw/.manifest.json — delta tracking of ingested sources",
  "type": "object",
  "required": ["version", "sources"],
  "additionalProperties": true,
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "description": {"type": "string"},
    "sources": {
      "type": "object",
      "patternProperties": {
        "^.+$": {
          "type": "object",
          "required": ["sha256", "ingested_at", "wiki_pages", "status"],
          "additionalProperties": false,
          "properties": {
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "ingested_at": {
              "type": "string",
              "format": "date-time"
            },
            "wiki_pages": {
              "type": "array",
              "items": {"type": "string"}
            },
            "status": {
              "type": "string",
              "enum": ["current", "updated", "superseded"]
            }
          }
        }
      }
    }
  }
}
